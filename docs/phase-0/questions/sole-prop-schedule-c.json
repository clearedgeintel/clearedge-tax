    {
      "sectionId": "vehicle-use",
      "title": "Vehicle Use",
      "description": "Business use of vehicle — Form 4562 Part V",
      "sortOrder": 4,
      "conditions": [
        { "questionId": "SCHC-EXP-002", "operator": "eq", "value": true }
      ],
      "repeatable": true,
      "questions": [
        {
          "questionId": "SCHC-VEH-001",
          "text": "Vehicle description (year, make, model)",
          "inputType": "text",
          "sortOrder": 1,
          "validation": { "required": true }
        },
        {
          "questionId": "SCHC-VEH-002",
          "text": "Date the vehicle was placed in service",
          "inputType": "date",
          "sortOrder": 2,
          "validation": { "required": true }
        },
        {
          "questionId": "SCHC-VEH-003",
          "text": "Total miles driven during the year",
          "inputType": "number",
          "sortOrder": 3,
          "validation": { "required": true, "min": 0 }
        },
        {
          "questionId": "SCHC-VEH-004",
          "text": "Business miles driven during the year",
          "inputType": "number",
          "sortOrder": 4,
          "validation": { "required": true, "min": 0 }
        },
        {
          "questionId": "SCHC-VEH-005",
          "text": "Commuting miles during the year",
          "inputType": "number",
          "sortOrder": 5,
          "validation": { "required": true, "min": 0 }
        },
        {
          "questionId": "SCHC-VEH-006",
          "text": "Which method would you like to use for vehicle expenses?",
          "helpText": "Standard mileage rate is simpler; actual expenses may yield a larger deduction",
          "inputType": "multiple_choice",
          "sortOrder": 6,
          "options": [
            { "value": "standard_mileage", "label": "Standard mileage rate" },
            { "value": "actual_expenses", "label": "Actual expenses" }
          ],
          "validation": { "required": true }
        },
        {
          "questionId": "SCHC-VEH-007",
          "text": "Total actual vehicle expenses (gas, oil, repairs, insurance, registration, etc.)",

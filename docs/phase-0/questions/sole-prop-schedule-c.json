{
  "metadata": {
    "fileId": "sole-prop-schedule-c",
    "entityTypes": ["sole-prop-schedule-c"],
    "version": "1.0.0",
    "taxYear": 2025,
    "description": "Schedule C (Profit or Loss From Business) intake questions for sole proprietorships and single-member LLCs. Referenced by the 1040 interview via section_include."
  },
  "sections": [
    {
      "sectionId": "business-info",
      "title": "Business Information",
      "description": "Basic business identification and setup",
      "sortOrder": 0,
      "questions": [
        {
          "questionId": "SCHC-BIZ-001",
          "text": "What is the name of your business?",
          "helpText": "If you don't have a formal business name, enter your own name",
          "inputType": "text",
          "sortOrder": 1,
          "validation": { "required": true }
        },
        {
          "questionId": "SCHC-BIZ-002",
          "text": "Does your business have an EIN (Employer Identification Number)?",
          "inputType": "yes_no",
          "sortOrder": 2,
          "validation": { "required": true }
        },
        {
          "questionId": "SCHC-BIZ-003",
          "text": "Business EIN",
          "inputType": "ein",
          "sortOrder": 3,
          "conditions": [
            { "questionId": "SCHC-BIZ-002", "operator": "eq", "value": true }
          ],
          "validation": { "required": true }
        },
        {
          "questionId": "SCHC-BIZ-004",
          "text": "Business address (if different from home address)",
          "inputType": "address",
          "sortOrder": 4,
          "validation": { "required": false }
        },
        {
          "questionId": "SCHC-BIZ-005",
          "text": "What is the principal business activity?",
          "helpText": "Describe what your business does (e.g., 'Consulting', 'Web Development', 'Landscaping')",
          "inputType": "text",
          "sortOrder": 5,
          "validation": { "required": true }
        },
        {
          "questionId": "SCHC-BIZ-006",
          "text": "Business activity code (NAICS)",
          "helpText": "6-digit code from the Principal Business Activity Codes list. Staff can assist with this.",
          "inputType": "text",
          "sortOrder": 6,
          "validation": { "required": true, "pattern": "^[0-9]{6}$" }
        },
        {
          "questionId": "SCHC-BIZ-007",
          "text": "What accounting method does the business use?",
          "inputType": "multiple_choice",
          "sortOrder": 7,
          "options": [
            { "value": "cash", "label": "Cash" },
            { "value": "accrual", "label": "Accrual" },
            { "value": "other", "label": "Other" }
          ],
          "validation": { "required": true }
        },
        {
          "questionId": "SCHC-BIZ-008",
          "text": "Describe the accounting method",
          "inputType": "text",
          "sortOrder": 8,
          "conditions": [
            { "questionId": "SCHC-BIZ-007", "operator": "eq", "value": "other" }
          ],
          "validation": { "required": true }
        },
        {
          "questionId": "SCHC-BIZ-009",
          "text": "Did you start or acquire this business during the tax year?",
          "inputType": "yes_no",
          "sortOrder": 9,
          "validation": { "required": true }
        },
        {
          "questionId": "SCHC-BIZ-010",
          "text": "Date the business started or was acquired",
          "inputType": "date",
          "sortOrder": 10,
          "conditions": [
            { "questionId": "SCHC-BIZ-009", "operator": "eq", "value": true }
          ],
          "validation": { "required": true }
        },
        {
          "questionId": "SCHC-BIZ-011",
          "text": "Did you make any payments that would require you to file Form 1099?",
          "helpText": "Generally, if you paid $600 or more to a non-employee for services",
          "inputType": "yes_no",
          "sortOrder": 11,
          "validation": { "required": true }
        },
        {
          "questionId": "SCHC-BIZ-012",
          "text": "Did you or will you file all required Forms 1099?",
          "inputType": "yes_no",
          "sortOrder": 12,
          "conditions": [
            { "questionId": "SCHC-BIZ-011", "operator": "eq", "value": true }
          ],
          "validation": { "required": true }
        },
        {
          "questionId": "SCHC-BIZ-013",
          "text": "Did you materially participate in the operation of this business during the tax year?",
          "helpText": "Material participation means you were involved in the business on a regular, continuous, and substantial basis",
          "inputType": "yes_no",
          "sortOrder": 13,
          "validation": { "required": true },
          "formTriggers": [
            {
              "formId": "form-8582",
              "formName": "Passive Activity Loss Limitations",
              "triggerWhen": { "operator": "eq", "value": false },
              "action": "include"
            }
          ]
        }
      ]
    },
    {
      "sectionId": "gross-income",
      "title": "Gross Income / Receipts",
      "description": "Total business revenue before expenses",
      "sortOrder": 1,
      "questions": [
        {
          "questionId": "SCHC-INC-001",
          "text": "What were your total gross receipts or sales for the year?",
          "helpText": "Include all income received from your business before any deductions",
          "inputType": "currency",
          "sortOrder": 1,
          "validation": { "required": true, "min": 0 }
        },
        {
          "questionId": "SCHC-INC-002",
          "text": "Did you have any returns and allowances?",
          "helpText": "Refunds, rebates, or discounts given to customers",
          "inputType": "yes_no",
          "sortOrder": 2,
          "validation": { "required": true }
        },
        {
          "questionId": "SCHC-INC-003",
          "text": "Total returns and allowances",
          "inputType": "currency",
          "sortOrder": 3,
          "conditions": [
            { "questionId": "SCHC-INC-002", "operator": "eq", "value": true }
          ],
          "validation": { "required": true, "min": 0 }
        },
        {
          "questionId": "SCHC-INC-004",
          "text": "Did you have any other business income not included in gross receipts?",
          "helpText": "For example: recovered bad debts, interest on business accounts, fuel tax credits",
          "inputType": "yes_no",
          "sortOrder": 4,
          "validation": { "required": true }
        },
        {
          "questionId": "SCHC-INC-005",
          "text": "Total other business income",
          "inputType": "currency",
          "sortOrder": 5,
          "conditions": [
            { "questionId": "SCHC-INC-004", "operator": "eq", "value": true }
          ],
          "validation": { "required": true, "min": 0 }
        },
        {
          "questionId": "SCHC-INC-006",
          "text": "Description of other business income",
          "inputType": "text",
          "sortOrder": 6,
          "conditions": [
            { "questionId": "SCHC-INC-004", "operator": "eq", "value": true }
          ]
        },
        {
          "questionId": "SCHC-INC-007",
          "text": "Did you receive any 1099-NEC or 1099-MISC forms for this business?",
          "inputType": "yes_no",
          "sortOrder": 7,
          "validation": { "required": true }
        },
        {
          "questionId": "SCHC-INC-008",
          "text": "Please upload all 1099-NEC and 1099-MISC forms",
          "inputType": "file_upload",
          "sortOrder": 8,
          "conditions": [
            { "questionId": "SCHC-INC-007", "operator": "eq", "value": true }
          ]
        }
      ]
    },
    {
      "sectionId": "cogs",
      "title": "Cost of Goods Sold",
      "description": "For businesses that sell products or have inventory",
      "sortOrder": 2,
      "conditions": [
        { "questionId": "SCHC-COGS-001", "operator": "eq", "value": true }
      ],
      "questions": [
        {
          "questionId": "SCHC-COGS-001",
          "text": "Does your business sell products or have inventory?",
          "inputType": "yes_no",
          "sortOrder": 1,
          "validation": { "required": true }
        },
        {
          "questionId": "SCHC-COGS-002",
          "text": "What inventory valuation method do you use?",
          "inputType": "multiple_choice",
          "sortOrder": 2,
          "options": [
            { "value": "cost", "label": "Cost" },
            { "value": "lower_of_cost_or_market", "label": "Lower of cost or market" },
            { "value": "other", "label": "Other" }
          ],
          "conditions": [
            { "questionId": "SCHC-COGS-001", "operator": "eq", "value": true }
          ],
          "validation": { "required": true }
        },
        {
          "questionId": "SCHC-COGS-003",
          "text": "Was there any change in determining quantities, costs, or valuations between opening and closing inventory?",
          "inputType": "yes_no",
          "sortOrder": 3,
          "conditions": [
            { "questionId": "SCHC-COGS-001", "operator": "eq", "value": true }
          ]
        },
        {
          "questionId": "SCHC-COGS-004",
          "text": "Inventory at beginning of year",
          "inputType": "currency",
          "sortOrder": 4,
          "conditions": [
            { "questionId": "SCHC-COGS-001", "operator": "eq", "value": true }
          ],
          "validation": { "required": true, "min": 0 }
        },
        {
          "questionId": "SCHC-COGS-005",
          "text": "Purchases less cost of items withdrawn for personal use",
          "inputType": "currency",
          "sortOrder": 5,
          "conditions": [
            { "questionId": "SCHC-COGS-001", "operator": "eq", "value": true }
          ],
          "validation": { "required": true, "min": 0 }
        },
        {
          "questionId": "SCHC-COGS-006",
          "text": "Cost of labor (not including amounts paid to yourself)",
          "inputType": "currency",
          "sortOrder": 6,
          "conditions": [
            { "questionId": "SCHC-COGS-001", "operator": "eq", "value": true }
          ],
          "validation": { "required": true, "min": 0 }
        },
        {
          "questionId": "SCHC-COGS-007",
          "text": "Materials and supplies",
          "inputType": "currency",
          "sortOrder": 7,
          "conditions": [
            { "questionId": "SCHC-COGS-001", "operator": "eq", "value": true }
          ],
          "validation": { "required": true, "min": 0 }
        },
        {
          "questionId": "SCHC-COGS-008",
          "text": "Other costs",
          "inputType": "currency",
          "sortOrder": 8,
          "conditions": [
            { "questionId": "SCHC-COGS-001", "operator": "eq", "value": true }
          ],
          "validation": { "min": 0 }
        },
        {
          "questionId": "SCHC-COGS-009",
          "text": "Inventory at end of year",
          "inputType": "currency",
          "sortOrder": 9,
          "conditions": [
            { "questionId": "SCHC-COGS-001", "operator": "eq", "value": true }
          ],
          "validation": { "required": true, "min": 0 }
        }
      ]
    },

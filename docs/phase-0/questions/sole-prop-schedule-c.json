          "sortOrder": 7,
          "conditions": [
            { "questionId": "SCHC-VEH-006", "operator": "eq", "value": "actual_expenses" }
          ],
          "validation": { "required": true, "min": 0 }
        },
        {
          "questionId": "SCHC-VEH-008",
